# Server environment variables
# Used when NODE_ENV=development
NODE_ENV=development

# API port (backend server listens on this)
PORT=5000

# Frontend origin(s) allowed for browser requests
CORS_ORIGINS=http://localhost:5500

# Logging format for morgan
LOG_FORMAT=dev

# Railway/MySQL (leave DATABASE_URL empty for local discrete config)
DATABASE_URL=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=restaurant_website

DB_SSL=false
DB_CONNECTION_LIMIT=10

