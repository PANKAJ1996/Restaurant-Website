NODE_ENV=development
PORT=5000

# Frontend origin(s) allowed for browser requests
# e.g. http://localhost:5500 or the port you use for your frontend
CORS_ORIGINS=http://localhost:5500

LOG_FORMAT=dev

# Railway/MySQL (local or hosted). For local testing you can use discrete vars.
# Recommended on Railway/Render: provide DATABASE_URL.
DATABASE_URL=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=restaurant_website
DB_SSL=false
DB_CONNECTION_LIMIT=10

